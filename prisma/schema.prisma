generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  phone         String?
  googleId      String?   @unique
  emailVerified DateTime?
  role          UserRole  @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings Booking[]
  orders   Order[]
  reviews  Review[]
  accounts Account[]
  sessions Session[]
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("admin")
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  CUSTOMER
  ADMIN
}

// ─── Menu ────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menuItems MenuItem[]
}

model MenuItem {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  image        String?
  categoryId   String
  isAvailable  Boolean  @default(true)
  isPopular    Boolean  @default(false)
  isVegetarian Boolean  @default(false)
  isVegan      Boolean  @default(false)
  isGlutenFree Boolean  @default(false)
  isSpicy      Boolean  @default(false)
  spiceLevel   Int      @default(0)
  allergens    String[] @default([])
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  comboItems ComboItem[]
  dishOfDay  DishOfDay[]

  @@index([categoryId])
  @@index([isAvailable])
}

// ─── Offers & Coupons ────────────────────────────────

model Offer {
  id          String    @id @default(cuid())
  title       String
  description String?
  code        String?   @unique
  discount    Decimal   @db.Decimal(5, 2)
  discountType DiscountType @default(PERCENTAGE)
  image       String?
  isActive    Boolean   @default(true)
  validFrom   DateTime  @default(now())
  validUntil  DateTime?
  minOrder    Decimal?  @db.Decimal(10, 2)
  maxUses     Int?
  usedCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Coupon {
  id           String       @id @default(cuid())
  code         String       @unique
  description  String?
  discount     Decimal      @db.Decimal(5, 2)
  discountType DiscountType @default(PERCENTAGE)
  minOrder     Decimal?     @db.Decimal(10, 2)
  maxDiscount  Decimal?     @db.Decimal(10, 2)
  maxUses      Int?
  usedCount    Int          @default(0)
  isActive     Boolean      @default(true)
  validFrom    DateTime     @default(now())
  validUntil   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─── Bookings ────────────────────────────────────────

model RestaurantTable {
  id            String        @id @default(cuid())
  tableNumber   Int           @unique
  capacity      Int           @default(4)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  bookings      Booking[]

  @@index([tableNumber])
  @@index([isActive])
}

model Booking {
  id              String        @id @default(cuid())
  userId          String?
  tableId         String?
  name            String
  email           String
  phone           String
  date            DateTime
  time            String
  endTime         String?       // Auto-calculated: time + 2:30
  guests          Int
  bookingType     BookingType   @default(TABLE)
  specialRequests String?       @db.Text
  status          BookingStatus @default(PENDING)
  reminderSent    Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user  User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  table RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([status])
  @@index([bookingType])
  @@index([userId])
  @@index([tableId])
  @@index([date, time])
}

enum BookingType {
  TABLE
  WEDDING
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// ─── Orders ──────────────────────────────────────────

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String?
  customerName    String
  customerEmail   String
  customerPhone   String
  type            OrderType     @default(PICKUP)
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod @default(CASH)
  paymentStatus   PaymentStatus @default(PENDING)
  subtotal        Decimal       @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  couponCode      String?
  pickupTime      DateTime?
  specialRequests String?       @db.Text
  stripeSessionId String?       @unique
  stripePaymentId String?
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  menuItemId String
  name       String
  price      Decimal @db.Decimal(10, 2)
  quantity   Int
  subtotal   Decimal @db.Decimal(10, 2)

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

enum OrderType {
  PICKUP
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  STRIPE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─── Contact & Reviews ──────────────────────────────

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String        @db.Text
  status    MessageStatus @default(UNREAD)
  repliedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

model Review {
  id        String       @id @default(cuid())
  userId    String?
  name      String
  rating    Int
  comment   String?      @db.Text
  isVisible Boolean      @default(true)
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([isVisible])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Gallery ─────────────────────────────────────────

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  caption   String?
  sortOrder Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Site Settings ───────────────────────────────────

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
  group String @default("general")

  @@index([group])
}

model OpeningHours {
  id        String  @id @default(cuid())
  dayOfWeek Int     @unique // 0=Sunday, 6=Saturday
  openTime  String  // "09:00"
  closeTime String  // "22:00"
  isClosed  Boolean @default(false)
}

model SeoSettings {
  id              String  @id @default(cuid())
  pageSlug        String  @unique
  title           String?
  description     String? @db.Text
  ogImage         String?
  canonicalUrl    String?
  noIndex         Boolean @default(false)
}

// ─── Email Logging ───────────────────────────────────

model EmailLog {
  id         String      @id @default(cuid())
  to         String
  subject    String
  template   String
  status     EmailStatus @default(SENT)
  resendId   String?
  error      String?     @db.Text
  sentAt     DateTime    @default(now())

  @@index([template])
  @@index([sentAt])
}

enum EmailStatus {
  SENT
  FAILED
  BOUNCED
}

// ─── Combo Meals ─────────────────────────────────────

model Combo {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  image         String?
  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal  @default(0) @db.Decimal(10, 2)
  savings       Decimal  @default(0) @db.Decimal(10, 2)
  servesCount   Int      @default(2)
  isAvailable   Boolean  @default(true)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items ComboItem[]

  @@index([isActive])
}

model ComboItem {
  id         String   @id @default(cuid())
  comboId    String
  menuItemId String
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())

  combo    Combo    @relation(fields: [comboId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([comboId])
  @@index([menuItemId])
}

// ─── Dish of the Day ─────────────────────────────────

model DishOfDay {
  id            String   @id @default(cuid())
  menuItemId    String
  discountPrice Decimal? @db.Decimal(10, 2)
  reason        String?
  date          DateTime @unique @db.Date
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([menuItemId])
}

// ─── Monitoring ──────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  adminEmail String
  action     String
  entity     String
  entityId   String?
  changes    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}

model ErrorLog {
  id          String   @id @default(cuid())
  message     String
  stack       String?  @db.Text
  path        String?
  method      String?
  statusCode  Int?
  requestId   String?
  fingerprint String?
  severity    String   @default("medium")
  context     Json?
  createdAt   DateTime @default(now())

  @@index([fingerprint])
  @@index([severity])
  @@index([createdAt])
  @@index([path])
}

model PerformanceLog {
  id         String   @id @default(cuid())
  path       String
  method     String?
  durationMs Float
  type       String   @default("api")
  statusCode Int?
  requestId  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([durationMs])
  @@index([createdAt])
  @@index([path])
}

// ─── Shisha Lounge ───────────────────────────────────

model ShishaTable {
  id          String             @id @default(cuid())
  tableNumber Int                @unique
  name        String             @default("")
  capacity    Int                @default(4)
  status      ShishaTableStatus  @default(AVAILABLE)
  isActive    Boolean            @default(true)
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  bookings ShishaBooking[]

  @@index([tableNumber])
  @@index([status])
  @@index([isActive])
}

enum ShishaTableStatus {
  AVAILABLE
  BOOKED
  TEMPORARILY_UNAVAILABLE
}

model ShishaBooking {
  id            String              @id @default(cuid())
  tableId       String
  customerName  String
  email         String
  phone         String
  bookingDate   DateTime
  bookingTime   String
  endTime       String?
  guests        Int
  status        ShishaBookingStatus @default(PENDING)
  notes         String?             @db.Text
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  table ShishaTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@index([bookingDate])
  @@index([status])
  @@index([bookingDate, bookingTime])
}

enum ShishaBookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model ShishaCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ShishaMenuItem[]

  @@index([slug])
  @@index([sortOrder])
}

model ShishaMenuItem {
  id              String   @id @default(cuid())
  categoryId      String
  name            String
  slug            String   @unique
  description     String?  @db.Text
  price           Float
  discountedPrice Float?
  image           String?
  images          String[] @default([])
  isAvailable     Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  sortOrder       Int      @default(0)
  tags            String[] @default([])
  intensity       Int?     // 1-5 for shisha strength
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category ShishaCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([slug])
  @@index([isAvailable])
  @@index([isFeatured])
  @@index([sortOrder])
}
